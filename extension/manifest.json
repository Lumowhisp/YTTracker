{
  "manifest_version": 3,
  "name": "YouTube Activity Tracker",
  "version": "2.0",
  "description": "Industry-grade YouTube activity tracking: watch time, categories, search queries, learning progress, and productivity insights.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Activity Tracker"
  }
}
